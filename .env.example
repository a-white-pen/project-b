# Database — Cloud SQL Auth Proxy binds to 5432 (or 5433 if taken)
DATABASE_URL=postgresql://user:password@localhost:5432/postgres

# Telegram bot credentials — from BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# Webhook secret — set this to any long random string, then register it with Telegram
# via: POST https://api.telegram.org/bot<token>/setWebhook?secret_token=<this-value>
TELEGRAM_WEBHOOK_SECRET=your-random-secret-here

# Gemini API key — get from https://aistudio.google.com/apikey
# Also add to Secret Manager: echo -n "your-key" | gcloud secrets create GEMINI_API_KEY --data-file=- --project awhitepen-project-b
GEMINI_API_KEY=your-gemini-api-key-here

# Bot's own public URL (needed for Cloud Tasks and webhook registration)
# Set after first Cloud Run deploy
BOT_URL=https://your-cloud-run-url.run.app

# USDA FoodData Central — whole foods macro lookup
# Register at https://fdc.nal.usda.gov/api-guide.html (free)
# Also add to Secret Manager: echo -n "your-key" | gcloud secrets create USDA_API_KEY --data-file=- --project awhitepen-project-b
USDA_API_KEY=your-usda-api-key-here