# Database — Cloud SQL Auth Proxy binds to 5432 (or 5433 if taken)
DATABASE_URL=postgresql://user:password@localhost:5432/postgres

# Telegram bot credentials — from BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# Webhook secret — set this to any long random string, then register it with Telegram
# via: POST https://api.telegram.org/bot<token>/setWebhook?secret_token=<this-value>
TELEGRAM_WEBHOOK_SECRET=your-random-secret-here

# Gemini API key — get from https://aistudio.google.com/apikey
# Also add to Secret Manager: echo -n "your-key" | gcloud secrets create GEMINI_API_KEY --data-file=- --project awhitepen-project-b
GEMINI_API_KEY=your-gemini-api-key-here

# Bot's own public URL (needed for Cloud Tasks and webhook registration)
# Set after first Cloud Run deploy
BOT_URL=https://your-cloud-run-url.run.app

# USDA FoodData Central — whole foods macro lookup
# Register at https://fdc.nal.usda.gov/api-guide.html (free)
# Also add to Secret Manager: echo -n "your-key" | gcloud secrets create USDA_API_KEY --data-file=- --project awhitepen-project-b
USDA_API_KEY=your-usda-api-key-here

# Strava — OAuth2 app credentials and pre-obtained refresh token
# Register app at https://www.strava.com/settings/api
# Refresh token: complete OAuth flow once, copy the refresh_token from the response
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_REFRESH_TOKEN=your-strava-refresh-token
# Arbitrary secret string used to verify Strava's webhook subscription handshake
STRAVA_WEBHOOK_VERIFY_TOKEN=your-random-verify-token
# Your Strava athlete ID — events from other owner_ids are rejected
STRAVA_OWNER_ID=your-strava-athlete-id

# Internal API key — sent as X-Internal-Key header by Cloud Scheduler to authenticate
# the POST /internal/refresh-nutrition endpoint. Use any long random string.
INTERNAL_API_KEY=your-random-internal-key-here

# Garmin Connect — no env vars needed in the app.
# Auth uses a DI OAuth2 token blob stored in system.garmin_tokens (one-time bootstrap):
#   garmin auth --email your@email.com --password yourpassword
# This writes the token blob to ~/.garminconnect/<user_id>/garmin_tokens.json.
# Copy it into system.garmin_tokens so Cloud Run can use it without re-authenticating.
# See inbound/garmin/client.py for the full token refresh flow.
